# Copy this file to .env and set your PostgreSQL values.
# Option A: use a single connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iluvpen

# Option B: use separate fields (used when DATABASE_URL is empty)
PGHOST=localhost
PGPORT=5432
PGDATABASE=iluvpen
PGUSER=postgres
PGPASSWORD=postgres

# Set to require when your cloud DB enforces SSL
PGSSLMODE=disable

# Comma-separated allowed origins for API CORS
# Example: https://yourname.github.io
CORS_ORIGIN=http://localhost:5173

# API server port
API_PORT=8787

# Frontend build-time API base URL (Vite)
# For local dev with Vite proxy, this can be empty.
# For GitHub Pages production, set this to your deployed API URL.
VITE_API_BASE_URL=
